# 本地开发端口。未填写时默认使用 8000。
VITE_DEV_PORT=8000

# 观远 BI 的服务地址，有前缀时需要携带前缀。
VITE_BI_HOST=https://app.guandata.com

# 目标环境的用户Token。优先级高于下面的账号密码登录配置。
VITE_UID_TOKEN=

# 账号密码登录的域。未填写时默认使用 guanbi；仅在未配置 VITE_UID_TOKEN 时生效。
VITE_BI_LOGIN_DOMAIN=guanbi

# 账号密码登录的账号。仅在未配置 VITE_UID_TOKEN 时生效。
VITE_BI_LOGIN_ID=

# 账号密码登录的密码。这里直接填写明文，脚本会在请求 /api/user/sign-in 前自动转成 base64。
VITE_BI_LOGIN_PASSWORD=

# 当前项目对应的 SuperApp ID。留空表示新建。
VITE_APP_ID=
