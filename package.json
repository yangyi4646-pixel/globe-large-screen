{
    "name": "@guandata/superapp-globe",
    "version": "0.1.1",
    "private": false,
    "type": "module",
    "description": "SuperApp Globe · 3D 地球美学库",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./styles": "./dist/index.css",
        "./templates/*": "./templates/*"
    },
    "files": [
        "dist",
        "templates",
        "bin",
        "README.md"
    ],
    "bin": {
        "superapp-globe-init": "bin/init.js"
    },
    "packageManager": "npm@10.9.2",
    "scripts": {
        "dev": "echo 'Use npm run dev:demo' && exit 1",
        "dev:demo": "vite --config demo/vite.config.mjs",
        "build": "tsup",
        "prepare": "npm run build",
        "build:demo": "vite build --config demo/vite.config.mjs",
        "preview:demo": "vite preview --config demo/vite.config.mjs",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "init": "node scripts/init.mjs",
        "design:lint": "node scripts/design-lint.mjs",
        "design:lint:strict": "node scripts/design-lint.mjs src/styles.css docs/design/skeleton-workbench.html docs/design/skeleton-dashboard.html",
        "format": "prettier scripts src tests --write",
        "format:check": "prettier scripts src tests --check",
        "lint": "tsc --noEmit && eslint scripts src tests",
        "lint:fix": "eslint scripts src tests --fix",
        "preview:open": "node scripts/preview.mjs"
    },
    "peerDependencies": {
        "@react-three/drei": "^9.0.0",
        "@react-three/fiber": "^8.0.0",
        "@react-three/postprocessing": "^2.0.0",
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "three": ">=0.160.0 <0.170.0"
    },
    "dependencies": {
        "@types/three": "0.169.0",
        "d3-geo": "^3.1.1",
        "lucide-react": "^0.541.0",
        "react-router-dom": "^6.30.1",
        "topojson-client": "^3.1.0",
        "world-atlas": "^2.0.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.23.0",
        "@react-three/drei": "^9.122.0",
        "@react-three/fiber": "^8.18.0",
        "@react-three/postprocessing": "^2.19.1",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@types/d3-geo": "^3.1.0",
        "@types/geojson": "^7946.0.16",
        "@types/react": "^18.3.20",
        "@types/react-dom": "^18.3.6",
        "@types/topojson-client": "^3.1.5",
        "@vitejs/plugin-react": "^4.4.1",
        "autoprefixer": "^10.5.0",
        "eslint": "^9.23.0",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^16.0.0",
        "jsdom": "^29.0.2",
        "postcss": "^8.5.15",
        "prettier": "^3.5.3",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tailwindcss": "^3.4.19",
        "three": "0.169.0",
        "tsup": "^8.5.1",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.28.0",
        "vite": "^5.4.19",
        "vitest": "^3.0.9",
        "yazl": "^3.3.1"
    }
}
